# =====================================================================
# GATO DUMAS DASHBOARD — VARIABLES DE ENTORNO (PLANTILLA)
# Copia este archivo a `.env.local` y completa los valores.
# NUNCA commitees `.env.local`.  Ver docs/SEGURIDAD_TOKENS.md
# =====================================================================

# ---------------------------------------------------------------------
# GOOGLE SHEETS — PERSISTENTE (sí queda guardado en .env.local)
# ---------------------------------------------------------------------
# Sheet oficial PROD: DB_Dashboard_Gato_Dumas_Meta_Ads_PROD
# Ruta: CookMinds / Clientes / Gato Dumas / Dashboard Pauta
# Owner: cookmindsagency@gmail.com
GOOGLE_SHEET_ID=1Mbh7nkLQttvZOGzMZtQpsMlk3sGeG3R854KjyTomF-k
# Email del service account (termina en .iam.gserviceaccount.com).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Clave privada del service account. Valor completo entre comillas,
# conservando los \n literales del JSON descargado.
GOOGLE_PRIVATE_KEY=

# ---------------------------------------------------------------------
# META ADS — cuentas (persistente, NO son secretos)
# ---------------------------------------------------------------------
META_API_VERSION=v22.0
META_AD_ACCOUNT_GATO_COLOMBIA=act_299121374587072
META_AD_ACCOUNT_GATO_BUCARAMANGA=act_248616958293893

# ---------------------------------------------------------------------
# META ADS — TOKEN TEMPORAL  ⚠️ NO guardar permanentemente
# ---------------------------------------------------------------------
# El token de Meta se renueva y NO debe vivir en .env.local.
# Se entrega SOLO al momento de actualizar datos, por corrida:
#
#   Forma A (oficial):
#     META_ACCESS_TOKEN="EAAB..." npm run meta:update -- --range this_month --updatedBy Paola
#
#   Forma B (interactiva, pide el token sin mostrarlo):
#     npm run meta:update:manual -- --range this_month --updatedBy Paola
#
# Déjalo VACÍO aquí. Ver docs/OPERACION_ACTUALIZACION.md y docs/SEGURIDAD_TOKENS.md
META_ACCESS_TOKEN=

# ---------------------------------------------------------------------
# APP
# ---------------------------------------------------------------------
NEXT_PUBLIC_CLIENT_NAME=Gato Dumas
NEXT_PUBLIC_TIMEZONE=America/Bogota
