# =====================================================================
# GATO DUMAS DASHBOARD — VARIABLES DE ENTORNO (PLANTILLA)
# =====================================================================
# Copia este archivo a `.env.local` y llena los valores reales.
# NUNCA commitees `.env.local`. Ver docs/SEGURIDAD_TOKENS.md
# =====================================================================

# ---------- META ADS ----------
# Token temporal de Meta (System User o token de usuario con ads_read).
# Se usa SOLO como variable de entorno local. No lo pegues en código.
META_ACCESS_TOKEN=
META_API_VERSION=v22.0

# IDs de cuentas publicitarias (formato act_XXXXXXXXX).
# Estos NO son secretos; ya vienen prellenados con las cuentas reales de Gato Dumas.
META_AD_ACCOUNT_GATO_COLOMBIA=act_299121374587072
META_AD_ACCOUNT_GATO_BUCARAMANGA=act_248616958293893

# ---------- GOOGLE SHEETS ----------
# ID del Google Sheet que actúa como base de datos viva.
GOOGLE_SHEET_ID=
# Email del service account (termina en .iam.gserviceaccount.com).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Clave privada del service account. Pega el valor completo entre comillas,
# conservando los \n literales tal como vienen en el JSON descargado.
# Ejemplo: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# ---------- APP ----------
NEXT_PUBLIC_CLIENT_NAME=Gato Dumas
NEXT_PUBLIC_TIMEZONE=America/Bogota
